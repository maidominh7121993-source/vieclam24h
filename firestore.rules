rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: userId, name, email, phone, avatar, credits, isVerified, createdAt, role
    //
    // Collection: jobs
    // Fields: jobId, title, employerId, employer, category, salary, location, description, contactPhone, isUrgent, isBoosted, status, createdAt
    //
    // Collection: applications
    // Fields: applicationId, jobId, applicantId, applicantName, applicantPhone, status, appliedAt
    //
    // Collection: notifications
    // Fields: id, type, userId, userName, amount, status, timestamp
    //
    // Collection: chats
    // Fields: chatId, participants, lastMessage, updatedAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "maidominh7121993@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.userId is string &&
             data.email is string &&
             data.name is string &&
             data.name.size() < 100 &&
             data.credits is number &&
             data.credits >= 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'avatar', 'location', 'credits']) &&
                      (request.resource.data.credits == resource.data.credits || request.resource.data.credits < resource.data.credits));
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.employerId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.employerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /applications/{appId} {
      allow read: if isAuthenticated() && (resource.data.applicantId == request.auth.uid || isAdmin() || 
                    get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.applicantId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
